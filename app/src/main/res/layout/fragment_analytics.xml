<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/gc_li_tv_title_analytics"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="ანალიტიკა"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <View
            android:id="@+id/gc_li_divider_2"
            android:layout_width="48dp"
            android:layout_height="3dp"
            android:background="@color/accent_gold"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/gc_li_tv_title_analytics"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/gc_li_tv_empty"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="80dp"
            android:text="\n\nგადადი 'შეყვანა' ტაბზე\nდა შეიყვანე მონაცემები"
            android:textSize="16sp"
            android:textColor="@color/text_muted"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            app:layout_constraintTop_toBottomOf="@id/gc_li_divider_2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <LinearLayout
            android:id="@+id/gc_li_group_data"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/gc_li_divider_2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/gc_li_tv_status_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="სტატუსი"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:textAllCaps="true"
                        android:letterSpacing="0.2"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <TextView
                        android:id="@+id/gc_li_tv_status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="—"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toBottomOf="@id/gc_li_tv_status_label"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/accent_gold_dim"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/gc_li_tv_final_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FINAL SAVINGS"
                        android:textSize="11sp"
                        android:textColor="@color/accent_gold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.25"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <TextView
                        android:id="@+id/gc_li_tv_final_savings"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="₾0.00"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_gold"
                        app:layout_constraintTop_toBottomOf="@id/gc_li_tv_final_label"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>

                    <TextView
                        android:id="@+id/gc_li_tv_formula_hint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="(შემოსავალი − ხარჯები) × K"
                        android:textSize="12sp"
                        android:textColor="@color/accent_gold"
                        android:alpha="0.7"
                        app:layout_constraintTop_toBottomOf="@id/gc_li_tv_final_savings"
                        app:layout_constraintStart_toStartOf="parent"/>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/bg_card"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:text="შემოსავალი"
                            android:textSize="11sp"
                            android:textColor="@color/accent_green"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:id="@+id/gc_li_tv_income"
                            android:text="₾0.00"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginTop="6dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="@color/bg_card"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:text="ხარჯები"
                            android:textSize="11sp"
                            android:textColor="@color/accent_red"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:id="@+id/gc_li_tv_expenses"
                            android:text="₾0.00"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginTop="6dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/gc_li_tv_net_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ნეტო ბალანსი"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:textAllCaps="true"
                        android:letterSpacing="0.15"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <TextView
                        android:id="@+id/gc_li_tv_net_balance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="₾0.00"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        app:layout_constraintTop_toBottomOf="@id/gc_li_tv_net_label"
                        app:layout_constraintStart_toStartOf="parent"/>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/gc_li_tv_k_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="K კოეფიციენტი"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:textAllCaps="true"
                        android:letterSpacing="0.15"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <TextView
                        android:id="@+id/gc_li_tv_k_coefficient"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="K = 1.4167"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_gold"
                        app:layout_constraintTop_toBottomOf="@id/gc_li_tv_k_label"
                        app:layout_constraintStart_toStartOf="parent"/>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:text="ხარჯების თანაფარდობა"
                            android:textSize="11sp"
                            android:textColor="@color/text_muted"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"/>

                        <TextView
                            android:id="@+id/gc_li_tv_expense_ratio"
                            android:text="0%"
                            android:textSize="13sp"
                            android:textColor="@color/accent_red"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/gc_li_progress_expenses"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="12dp"
                        android:progressDrawable="@drawable/progress_drawable"
                        android:max="100"
                        android:progress="0"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:text="დანაზოგის პროცენტი:"
                            android:textSize="13sp"
                            android:textColor="@color/text_muted"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"/>

                        <TextView
                            android:id="@+id/gc_li_tv_savings_rate"
                            android:text="0%"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/accent_green"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
